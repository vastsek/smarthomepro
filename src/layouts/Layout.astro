---
// Αρχείο: src/layouts/Layout.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description: descriptionProp } = Astro.props;

// Εδώ ορίζουμε την περιγραφή που θα φαίνεται στη Google
// (τώρα μπορεί να διαφέρει ανά σελίδα μέσω του description prop)
const description = descriptionProp ?? "Λύσεις Smart Home KNX στην Αθήνα και την Αττική για αρχιτέκτονες, μηχανικούς και ιδιοκτήτες κατοικιών. Μελέτη, Εγκατάσταση και Integration συστημάτων αυτοματισμού.";
const siteUrl = "https://smarthomepro.gr";
const ogImage = "https://smarthomepro.gr/images/og-cover.jpg"; // TODO: ανέβασε εδώ πραγματική φωτογραφία έργου (βλ. σημείωση στο Hero.astro)

// JSON-LD structured data ώστε η Google να καταλαβαίνει επιχείρηση/τοποθεσία/υπηρεσία
const localBusinessSchema = {
	"@context": "https://schema.org",
	"@type": "ProfessionalService",
	"name": "SmartHomePro",
	"description": description,
	"url": siteUrl,
	"telephone": "+302102200607",
	"email": "info@smarthomepro.gr",
	"image": ogImage,
	"areaServed": {
		"@type": "State",
		"name": "Αττική"
	},
	"address": {
		"@type": "PostalAddress",
		"addressRegion": "Αττική",
		"addressCountry": "GR"
	},
	"priceRange": "€€€",
	"knowsAbout": ["KNX", "Smart Home", "Οικιακός Αυτοματισμός", "Home Automation", "GRMS", "Ασθενή Ρεύματα", "Δίκτυα", "Δομημένη Καλωδίωση", "Συστήματα Ασφαλείας", "Κάμερες", "VoIP"]
};
---

<!doctype html>
<html lang="el" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />

        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="robots" content="index, follow" />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={siteUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={siteUrl} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={ogImage} />

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

        <!-- Structured data: βοηθάει τη Google να καταλάβει επιχείρηση/τοποθεσία/υπηρεσίες -->
        <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

        <style is:global>
            /* --- Καλλιτεχνικό σύστημα backgrounds ---
               Reusable treatments ώστε τα sections να έχουν συνεπή ρυθμό, βάθος και υφή. */

            /* Ανοιχτό section με διακριτικό dot-grid (engineering/blueprint αίσθηση).
               Το πρώτο layer είναι απαλό λευκό fade στην κορυφή, ώστε το section να
               «αναδύεται» μαλακά από το λευκό section που προηγείται (soft transition). */
            .bg-dotted {
                background-color: #f8fafc; /* slate-50 */
                background-image:
                    linear-gradient(to bottom, #ffffff, rgb(255 255 255 / 0) 160px),
                    radial-gradient(rgb(15 23 42 / 0.05) 1px, transparent 1px);
                background-size: 100% 100%, 22px 22px;
                background-repeat: no-repeat, repeat;
            }

            /* Σκούρο navy section με απαλό μπλε glow στην κορυφή (βάθος αντί για flat) */
            .bg-dark-glow {
                background-color: #0f172a; /* slate-900 */
                background-image: radial-gradient(55% 45% at 50% 0%, rgb(37 99 235 / 0.18), transparent 70%);
            }

            /* Scroll-reveal micro-interactions (fade-up καθώς εμφανίζονται τα blocks).
               Σέβεται το prefers-reduced-motion και δεν κρύβει περιεχόμενο χωρίς JS. */
            @media (prefers-reduced-motion: no-preference) {
                .reveal {
                    opacity: 0;
                    transform: translateY(22px);
                    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
                    will-change: opacity, transform;
                }
                .reveal.is-visible {
                    opacity: 1;
                    transform: none;
                }
            }
        </style>
	</head>
	<body class="font-['Inter'] antialiased bg-white text-slate-800">
        <Header />
		<slot />
        <Footer />

        <script>
            // Scroll-reveal: κάνει fade-up τα κύρια blocks καθώς μπαίνουν στο viewport.
            const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            if (!reduce) {
                const io = new IntersectionObserver((entries) => {
                    for (const entry of entries) {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('is-visible');
                            io.unobserve(entry.target);
                        }
                    }
                }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });

                const tag = (container: Element | null) => {
                    if (!container) return;
                    Array.from(container.children).forEach((el, i) => {
                        const pos = getComputedStyle(el).position;
                        if (pos === 'absolute' || pos === 'fixed') return;
                        el.classList.add('reveal');
                        (el as HTMLElement).style.transitionDelay = Math.min(i * 90, 270) + 'ms';
                        io.observe(el);
                    });
                };

                // Homepage: κάθε section (εκτός του πρώτου = hero, που είναι above the fold)
                document.querySelectorAll('main > section').forEach((sec, i) => {
                    if (i === 0) return;
                    tag(sec.querySelector(':scope > div'));
                });
                // Εσωτερικές σελίδες: main > div.container
                document.querySelectorAll('main > div').forEach((c) => tag(c));
            }
        </script>
	</body>
</html>