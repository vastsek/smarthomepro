---
// Αρχείο: src/components/Projects.astro
import { projects } from '../data/projects';

const featuredSlugs = ['katoikia-glyfada', 'monokatoikia-filothei', 'grafeia-ag-dimitrios', 'cctv-sepolia'];
const featured = featuredSlugs
	.map((slug) => projects.find((p) => p.slug === slug))
	.filter((p): p is NonNullable<typeof p> => Boolean(p));
---

<section id="projects" class="py-24 bg-white">
    <div class="container mx-auto px-6">

        <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
            <div class="max-w-2xl">
                <span class="eyebrow">Case Studies</span>
                <h2 class="text-3xl md:text-5xl font-bold text-slate-900 mt-2">
                    Τα Έργα Μας
                </h2>
                <p class="text-slate-600 text-lg mt-6">
                    Πραγματικές εγκαταστάσεις KNX και ασθενών συστημάτων, από κατοικίες μέχρι επαγγελματικούς χώρους.
                </p>
            </div>

            <a href="/projects/" class="hidden md:flex items-center gap-2 text-slate-900 font-semibold hover:text-teal-600 transition-colors">
                Δείτε όλα τα έργα
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3" />
                </svg>
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {featured.map((project) => (
                <a href={`/projects/${project.slug}/`} class="group block">
                    <div class:list={["relative overflow-hidden rounded-xl aspect-[4/3] mb-6", project.imageFit === 'contain' ? 'flex items-center justify-center bg-gradient-to-br from-slate-800 via-slate-900 to-black' : '']}>
                        {project.imageFit === 'contain' && (
                            <div class="absolute w-40 h-40 bg-teal-500/20 rounded-full blur-3xl"></div>
                        )}
                        <img
                            src={project.gallery[0].src}
                            alt={project.title}
                            class:list={["transition-transform duration-700 group-hover:scale-110", project.imageFit === 'contain' ? 'relative h-[85%] w-auto max-w-[80%] object-contain rounded-xl shadow-2xl ring-1 ring-white/10' : 'w-full h-full object-cover']}
                        />
                        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/0 transition-colors"></div>
                    </div>
                    <div class="flex items-center gap-3 text-sm text-teal-600 font-medium mb-2">
                        <span>{project.category}</span>
                        <span>•</span>
                        <span>{project.tags.join(' · ')}</span>
                    </div>
                    <h3 class="text-2xl font-bold text-slate-900 mb-2 group-hover:text-teal-600 transition-colors">{project.title}</h3>
                    <p class="text-slate-500">
                        {project.description}
                    </p>
                </a>
            ))}
        </div>

        <div class="mt-12 text-center md:hidden">
            <a href="/projects/" class="inline-flex items-center gap-2 text-slate-900 font-semibold hover:text-teal-600 transition-colors">
                Δείτε όλα τα έργα
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3" />
                </svg>
            </a>
        </div>
    </div>
</section>
