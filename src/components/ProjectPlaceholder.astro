---
// Placeholder για έργα «εν εξελίξει» χωρίς φωτογραφικό υλικό.
// Γεμίζει τον γονικό (relative) container — αντικαθιστά την <img>.
interface Props {
	compact?: boolean;
}
const { compact = false } = Astro.props;
---

<div class="absolute inset-0 flex flex-col items-center justify-center gap-3 bg-gradient-to-br from-slate-800 via-slate-900 to-slate-950 px-4 text-center">
	<div class="pointer-events-none absolute w-40 h-40 bg-amber-400/10 rounded-full blur-3xl"></div>

	<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class:list={["relative text-amber-400", compact ? "w-7 h-7" : "w-11 h-11"]}>
		<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l5.656-4.656c.34-.28.786-.468 1.255-.468h.057M17.25 21 21 17.25m-9.58-12.08-.242-.242a2.572 2.572 0 0 0-3.636 3.636l.242.242m0 0 .243.243a2.572 2.572 0 0 0 3.635-3.636l-.242-.242" />
	</svg>

	<span class="relative inline-flex items-center gap-2 text-amber-400 font-bold tracking-wider uppercase text-xs">
		<span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
		Εν εξελίξει
	</span>

	{!compact && (
		<span class="relative text-slate-400 text-xs">Φωτογραφικό υλικό σύντομα</span>
	)}
</div>
