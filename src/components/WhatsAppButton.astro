---
// Αρχείο: src/components/WhatsAppButton.astro
// Floating κουμπί WhatsApp (κάτω δεξιά, σε όλες τις σελίδες μέσω Layout).
//
// ΔΙΑΚΟΠΤΗΣ: γύρνα το σε true ΜΟΝΟ όταν ενεργοποιηθεί το WhatsApp Business
// στο 210 220 0607 — αλλιώς όποιος πατάει βλέπει «ο αριθμός δεν είναι στο WhatsApp».
const WHATSAPP_ENABLED = false;

const phone = '302102200607';
const message = encodeURIComponent('Καλησπέρα! Θα ήθελα πληροφορίες για ένα έργο.');
const href = `https://wa.me/${phone}?text=${message}`;
---

{WHATSAPP_ENABLED && (
	<a
		href={href}
		target="_blank"
		rel="noopener"
		aria-label="Μιλήστε μας στο WhatsApp"
		data-umami-event="whatsapp-click"
		class="fixed bottom-6 right-6 z-30 flex items-center justify-center w-14 h-14 rounded-full bg-[#25D366] text-white shadow-lg shadow-black/20 hover:scale-110 hover:shadow-xl transition-all"
	>
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7" aria-hidden="true">
			<path d="M12.04 2c-5.46 0-9.9 4.44-9.9 9.9 0 1.75.46 3.45 1.32 4.95L2.05 22l5.27-1.38a9.9 9.9 0 0 0 4.72 1.2h.01c5.46 0 9.9-4.44 9.9-9.9 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.15h-.01a8.2 8.2 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.23 8.23Zm4.52-6.16c-.25-.13-1.47-.72-1.69-.8-.23-.09-.4-.13-.56.12-.17.25-.64.8-.78.97-.15.17-.29.19-.54.06-.25-.12-1.05-.38-1.99-1.23a7.44 7.44 0 0 1-1.38-1.71c-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.12-.15.16-.25.25-.42.08-.17.04-.31-.02-.43-.06-.13-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42h-.48c-.17 0-.43.06-.66.31-.22.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.6.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.15-1.18-.06-.1-.23-.16-.48-.29Z" />
		</svg>
	</a>
)}
