---
// Αρχείο: src/components/Footer.astro
import { Image } from 'astro:assets';
import knxPartner from '../assets/images/knx-partner.jpg';

const year = new Date().getFullYear();
---

<footer class="bg-dark-glow text-slate-400 py-12 border-t border-slate-800">
    <div class="container mx-auto px-6">
        <div class="flex flex-col md:flex-row justify-between items-center gap-10">
            
            <div class="text-center md:text-left flex flex-col items-center md:items-start">
                
                <div class="flex items-center gap-6 mb-6">
                    <img
                        src="/images/SmartHomePro_Hor_W.png"
                        alt="SmartHomePro"
                        width="1350"
                        height="683"
                        loading="lazy"
                        class="h-12 md:h-16 w-auto object-contain"
                    />
                    
                    <div class="w-px h-10 bg-slate-700"></div>

                    <div class="bg-white rounded-lg px-3 py-2 flex items-center">
                        <Image
                            src={knxPartner}
                            alt="Πιστοποιημένος KNX Partner"
                            height={80}
                            loading="lazy"
                            class="h-8 md:h-10 w-auto object-contain"
                        />
                    </div>
                </div>

                <p class="text-sm">
                    &copy; {year} SmartHomePro. All rights reserved.
                </p>
            </div>

            <div class="text-center">
                <h4 class="text-white font-bold mb-4 uppercase tracking-wider text-sm">Επικοινωνία</h4>
                <a href="tel:+302102200607" class="text-xl md:text-2xl font-bold text-white hover:text-teal-400 transition-colors flex items-center gap-3 justify-center group whitespace-nowrap">
                    <div class="p-2 bg-slate-800 rounded-full group-hover:bg-teal-600 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                        </svg>
                    </div>
                    210 220 0607
                </a>
            </div>

            <div class="text-center md:text-right">
                <h4 class="text-white font-bold mb-4 uppercase tracking-wider text-sm">Ακολουθήστε μας</h4>
                <div class="flex items-center justify-center md:justify-end gap-3">
                    <a href="https://www.facebook.com/smarthomepro.gr/" target="_blank" rel="noopener" aria-label="Facebook" class="p-2.5 bg-slate-800 rounded-full text-slate-300 hover:bg-teal-600 hover:text-white transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
                            <path d="M13.5 21.9v-7.4h2.5l.4-2.9h-2.9V9.7c0-.8.4-1.7 1.8-1.7h1.4V5.5s-1.3-.2-2.5-.2c-2.5 0-4.2 1.5-4.2 4.3v2h-2.6v2.9h2.6v7.4a10 10 0 0 0 3.5 0Z" />
                        </svg>
                    </a>
                    <a href="https://www.instagram.com/smarthomepro.gr/" target="_blank" rel="noopener" aria-label="Instagram" class="p-2.5 bg-slate-800 rounded-full text-slate-300 hover:bg-teal-600 hover:text-white transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
                            <path d="M12 2.2c3.2 0 3.6 0 4.9.1 1.2.1 1.8.2 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1 .4 2.2.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c-.1 1.2-.2 1.8-.4 2.2a3.8 3.8 0 0 1-.9 1.4c-.4.4-.8.7-1.4.9-.4.2-1 .4-2.2.4-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2-.1-1.8-.2-2.2-.4a3.8 3.8 0 0 1-1.4-.9 3.8 3.8 0 0 1-.9-1.4c-.2-.4-.4-1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.9c.1-1.2.2-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.4 2.2-.4C8.4 2.2 8.8 2.2 12 2.2Zm0 1.8c-3.1 0-3.5 0-4.8.1-1.1.1-1.5.2-1.7.3-.4.2-.7.4-1 .7-.3.3-.5.6-.7 1-.1.2-.2.6-.3 1.7-.1 1.3-.1 1.7-.1 4.8s0 3.5.1 4.8c.1 1.1.2 1.5.3 1.7.2.4.4.7.7 1 .3.3.6.5 1 .7.2.1.6.2 1.7.3 1.3.1 1.7.1 4.8.1s3.5 0 4.8-.1c1.1-.1 1.5-.2 1.7-.3.4-.2.7-.4 1-.7.3-.3.5-.6.7-1 .1-.2.2-.6.3-1.7.1-1.3.1-1.7.1-4.8s0-3.5-.1-4.8c-.1-1.1-.2-1.5-.3-1.7-.2-.4-.4-.7-.7-1a2 2 0 0 0-1-.7c-.2-.1-.6-.2-1.7-.3-1.3-.1-1.7-.1-4.8-.1Zm0 3a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.8a3.2 3.2 0 1 0 0 6.4 3.2 3.2 0 0 0 0-6.4Zm5.2-3.1a1.2 1.2 0 1 1 0 2.4 1.2 1.2 0 0 1 0-2.4Z" />
                        </svg>
                    </a>
                    <a href="https://www.linkedin.com/company/smarthomeprogreece/" target="_blank" rel="noopener" aria-label="LinkedIn" class="p-2.5 bg-slate-800 rounded-full text-slate-300 hover:bg-teal-600 hover:text-white transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
                            <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45Z" />
                        </svg>
                    </a>
                    <a href="https://maps.app.goo.gl/fc3hQA4pmtnAhWP26" target="_blank" rel="noopener" aria-label="Google Maps" class="p-2.5 bg-slate-800 rounded-full text-slate-300 hover:bg-teal-600 hover:text-white transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
                            <path d="M12 2a7.5 7.5 0 0 0-7.5 7.5c0 5.6 6.6 11.8 6.9 12.1a.9.9 0 0 0 1.2 0c.3-.3 6.9-6.5 6.9-12.1A7.5 7.5 0 0 0 12 2Zm0 10.1a2.6 2.6 0 1 1 0-5.2 2.6 2.6 0 0 1 0 5.2Z" />
                        </svg>
                    </a>
                </div>
            </div>

        </div>

        <p class="mt-10 pt-6 border-t border-slate-800 text-center text-xs text-slate-500">
            KNX and ETS are registered trademarks of KNX Association cvba Belgium and are used with kind permission.
        </p>
    </div>
</footer>