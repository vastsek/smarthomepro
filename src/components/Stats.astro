---
// Αρχείο: src/components/Stats.astro
// Μπάντα social proof με πραγματικά/επαληθεύσιμα στοιχεία (χωρίς επινοημένους αριθμούς έργων).
const stats = [
    { value: '2006', label: 'Πιστοποιημένος KNX Partner' },
    { value: '20+', label: 'Χρόνια εμπειρίας' },
    { value: '15+', label: 'Κορυφαίες μάρκες συνεργασίας' },
    { value: '100%', label: 'Πανελλαδική κάλυψη & υποστήριξη' },
];
---

<section class="relative overflow-hidden py-16 bg-gradient-to-br from-emerald-500 via-teal-600 to-teal-700 text-white">
    <div class="pointer-events-none absolute -top-1/3 left-1/2 -translate-x-1/2 w-[700px] h-[400px] bg-emerald-300/20 rounded-full blur-[120px]"></div>

    <div class="container mx-auto px-6 relative">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-y-10 gap-x-6">
            {stats.map((stat) => (
                <div class="text-center">
                    <div class="text-4xl md:text-5xl font-bold tracking-tight">{stat.value}</div>
                    <div class="text-teal-100 text-sm md:text-base mt-2 leading-snug max-w-[15ch] mx-auto">{stat.label}</div>
                </div>
            ))}
        </div>
    </div>
</section>
