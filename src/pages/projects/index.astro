---
// Αρχείο: src/pages/projects/index.astro
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects';
---

<Layout
	title="Τα Έργα Μας | SmartHomePro - KNX & Ασθενή Συστήματα"
	description="Πραγματικές εγκαταστάσεις KNX, δομημένης καλωδίωσης και συστημάτων ασφαλείας από την SmartHomePro, σε κατοικίες και επαγγελματικούς χώρους στην Αττική."
>
	<main class="pt-40 pb-24">
		<div class="container mx-auto px-6">

			<div class="max-w-2xl mb-16">
				<span class="eyebrow">Case Studies</span>
				<h1 class="text-4xl md:text-5xl font-bold text-slate-900 mt-2">
					Τα Έργα Μας
				</h1>
				<p class="text-slate-600 text-lg mt-6">
					Πραγματικές εγκαταστάσεις KNX και ασθενών συστημάτων, από κατοικίες μέχρι επαγγελματικούς χώρους στην Αττική.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{projects.map((project) => (
					<a href={`/projects/${project.slug}/`} class="group block">
						<div class:list={["relative overflow-hidden rounded-xl aspect-[4/3] mb-6", project.imageFit === 'contain' ? 'flex items-center justify-center bg-gradient-to-br from-slate-800 via-slate-900 to-black' : '']}>
							{project.imageFit === 'contain' && (
								<div class="absolute w-40 h-40 bg-teal-500/20 rounded-full blur-3xl"></div>
							)}
							<img
								src={project.gallery[0].src}
								alt={project.title}
								class:list={["transition-transform duration-700 group-hover:scale-110", project.imageFit === 'contain' ? 'relative h-[85%] w-auto max-w-[80%] object-contain rounded-xl shadow-2xl ring-1 ring-white/10' : 'w-full h-full object-cover']}
							/>
							<div class="absolute inset-0 bg-black/20 group-hover:bg-black/0 transition-colors"></div>
						</div>
						<div class="flex items-center gap-3 text-sm text-teal-600 font-medium mb-2">
							<span>{project.category}</span>
							<span>•</span>
							<span>{project.tags.join(' · ')}</span>
						</div>
						<h2 class="text-2xl font-bold text-slate-900 mb-1 group-hover:text-teal-600 transition-colors">{project.title}</h2>
						<p class="text-sm text-slate-400 mb-3">{project.location}</p>
						<p class="text-slate-500">
							{project.description}
						</p>
					</a>
				))}
			</div>

			<div class="mt-16 p-8 bg-dark-glow rounded-xl text-center">
				<h3 class="text-2xl font-bold text-white mb-4">Θέλετε το δικό σας έργο εδώ;</h3>
				<a href="/#contact" class="inline-block px-8 py-4 bg-teal-600 text-white text-base font-medium rounded hover:bg-teal-500 transition-colors shadow-lg">
					Ζητήστε Μελέτη
				</a>
			</div>

		</div>
	</main>
</Layout>
