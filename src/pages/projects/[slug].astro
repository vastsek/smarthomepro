---
// Αρχείο: src/pages/projects/[slug].astro
import { Image, getImage } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects';
import ProjectPlaceholder from '../../components/ProjectPlaceholder.astro';

export function getStaticPaths() {
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;
const otherProjects = projects.filter((p) => p.slug !== project.slug).slice(0, 3);

// og:image: βελτιστοποιημένη εκδοχή (JPEG, max 1200px) της πρώτης εικόνας του gallery.
const ogImage = project.gallery[0]
	? (await getImage({ src: project.gallery[0].src, width: Math.min(1200, project.gallery[0].src.width), format: 'jpeg' })).src
	: undefined;
---

<Layout
	title={`${project.title} | Έργα SmartHomePro`}
	description={project.description}
	ogImage={ogImage}
	breadcrumbs={[
		{ name: 'Αρχική', url: '/' },
		{ name: 'Έργα', url: '/projects/' },
		{ name: project.title },
	]}
>
	<main class="pt-40 pb-24">
		<div class="container mx-auto px-6 max-w-5xl">

			<a href="/projects/" class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-teal-600 transition-colors mb-6">
				<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
					<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
				</svg>
				Πίσω σε όλα τα έργα
			</a>

			<div class="flex items-center flex-wrap gap-3 text-sm text-teal-600 font-medium mb-3">
				<span>{project.category}</span>
				<span>•</span>
				<span>{project.tags.join(' · ')}</span>
				{project.status === 'in-progress' && (
					<span class="inline-flex items-center gap-2 rounded-full bg-amber-100 text-amber-700 px-3 py-1 text-xs font-bold uppercase tracking-wider">
						<span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span>
						Εν εξελίξει
					</span>
				)}
			</div>
			<h1 class="text-3xl md:text-5xl font-bold text-slate-900 mb-3">{project.title}</h1>
			<p class="text-slate-400 mb-8">{project.location}</p>

			<p class="text-slate-700 text-lg leading-relaxed max-w-3xl mb-12">
				{project.longDescription}
			</p>

			{project.gallery.length > 0 ? (
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
					{project.gallery.map((img) => {
						const fit = img.fit ?? project.imageFit;
						return (
							<figure class:list={["rounded-xl overflow-hidden", fit === 'contain' ? 'bg-gradient-to-br from-slate-800 via-slate-900 to-black' : '']}>
								<div class:list={["relative aspect-[4/3]", fit === 'contain' ? 'flex items-center justify-center' : '']}>
									{fit === 'contain' && (
										<div class="absolute w-40 h-40 bg-teal-500/20 rounded-full blur-3xl"></div>
									)}
									<Image
										src={img.src}
										alt={img.caption}
										widths={[480, 768, 1024]}
										sizes="(min-width: 768px) 50vw, 100vw"
										loading="lazy"
										class:list={["", fit === 'contain' ? 'relative h-[85%] w-auto max-w-[80%] object-contain rounded-xl shadow-2xl ring-1 ring-white/10' : 'w-full h-full object-cover']}
									/>
								</div>
								<figcaption class="text-sm text-slate-500 mt-3">{img.caption}</figcaption>
							</figure>
						);
					})}
				</div>
			) : (
				<div class="relative aspect-[16/9] md:aspect-[21/9] rounded-xl overflow-hidden mb-16">
					<ProjectPlaceholder />
				</div>
			)}

			{project.sections && project.sections.length > 0 && (
				<div class="max-w-3xl space-y-10 mb-16">
					{project.sections.map((s) => (
						<div>
							<h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-4">{s.heading}</h2>
							{s.body && <p class="text-slate-700 text-lg leading-relaxed">{s.body}</p>}
							{s.points && s.points.length > 0 && (
								<ul class="mt-6 space-y-4">
									{s.points.map((pt) => (
										<li class="flex gap-3">
											<span class="mt-2.5 w-1.5 h-1.5 rounded-full bg-teal-500 shrink-0"></span>
											<span class="text-slate-700 leading-relaxed"><strong class="text-slate-900 font-semibold">{pt.label}:</strong> {pt.text}</span>
										</li>
									))}
								</ul>
							)}
						</div>
					))}
				</div>
			)}

			{project.specs && project.specs.length > 0 && (
				<div class="max-w-3xl mb-16">
					<h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-6">Τεχνικό Παράρτημα</h2>
					<dl class="rounded-xl border border-slate-100 overflow-hidden divide-y divide-slate-100">
						{project.specs.map((sp) => (
							<div class="flex flex-col sm:flex-row sm:gap-6 px-5 py-4 even:bg-slate-50/60">
								<dt class="font-semibold text-slate-900 sm:w-64 shrink-0">{sp.label}</dt>
								<dd class="text-slate-600 leading-relaxed">{sp.value}</dd>
							</div>
						))}
					</dl>
				</div>
			)}

			<div class="p-8 bg-dark-glow rounded-xl text-center mb-16">
				<h3 class="text-2xl font-bold text-white mb-4">Θέλετε ένα αντίστοιχο έργο για τον δικό σας χώρο;</h3>
				<a href="/#contact" class="inline-block px-8 py-4 bg-teal-600 text-white text-base font-medium rounded hover:bg-teal-500 transition-colors shadow-lg">
					Ζητήστε Μελέτη
				</a>
			</div>

			{otherProjects.length > 0 && (
				<div>
					<h3 class="text-xl font-bold text-slate-900 mb-6">Άλλα έργα</h3>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
						{otherProjects.map((p) => (
							<a href={`/projects/${p.slug}/`} class="group block">
								<div class:list={["relative overflow-hidden rounded-xl aspect-[4/3] mb-4", p.gallery.length > 0 && p.imageFit === 'contain' ? 'flex items-center justify-center bg-gradient-to-br from-slate-800 via-slate-900 to-black' : '']}>
									{p.gallery.length === 0 ? (
										<ProjectPlaceholder compact />
									) : (
										<Fragment>
											{p.imageFit === 'contain' && (
												<div class="absolute w-32 h-32 bg-teal-500/20 rounded-full blur-3xl"></div>
											)}
											<Image
												src={p.gallery[0].src}
												alt={p.title}
												widths={[320, 480, 640]}
												sizes="(min-width: 768px) 33vw, 100vw"
												loading="lazy"
												class:list={["transition-transform duration-700 group-hover:scale-110", p.imageFit === 'contain' ? 'relative h-[85%] w-auto max-w-[80%] object-contain rounded-xl shadow-2xl ring-1 ring-white/10' : 'w-full h-full object-cover']}
											/>
										</Fragment>
									)}
								</div>
								<h4 class="font-bold text-slate-900 group-hover:text-teal-600 transition-colors">{p.title}</h4>
							</a>
						))}
					</div>
				</div>
			)}

		</div>
	</main>
</Layout>
