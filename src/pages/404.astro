---
// Αρχείο: src/pages/404.astro
// Custom σελίδα 404 — το Netlify τη σερβίρει αυτόματα από το dist/404.html.
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Η σελίδα δεν βρέθηκε | SmartHomePro"
	description="Η σελίδα που ψάχνετε δεν υπάρχει ή έχει μετακινηθεί."
	noindex={true}
>
	<main>
		<section class="bg-dotted min-h-screen flex items-center justify-center py-32 px-6">
			<div class="max-w-xl w-full text-center">

				<p class="text-7xl md:text-8xl font-bold text-teal-600/20 mb-6">404</p>

				<h1 class="text-3xl md:text-5xl font-bold text-slate-900 mb-4">
					Η σελίδα δεν βρέθηκε
				</h1>
				<p class="text-slate-600 text-lg mb-10">
					Η σελίδα που ψάχνετε δεν υπάρχει ή έχει μετακινηθεί. Δοκιμάστε έναν από τους παρακάτω προορισμούς.
				</p>

				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href="/" class="px-8 py-4 bg-gradient-to-r from-emerald-500 to-teal-600 text-white font-bold rounded-lg hover:from-emerald-400 hover:to-teal-500 transition-all shadow-lg shadow-teal-600/20">
						Αρχική σελίδα
					</a>
					<a href="/projects/" class="px-8 py-4 bg-white text-slate-900 font-bold rounded-lg border border-slate-200 hover:border-teal-500 hover:text-teal-600 transition-all">
						Τα έργα μας
					</a>
					<a href="/blog/" class="px-8 py-4 bg-white text-slate-900 font-bold rounded-lg border border-slate-200 hover:border-teal-500 hover:text-teal-600 transition-all">
						Blog
					</a>
				</div>

			</div>
		</section>
	</main>
</Layout>
