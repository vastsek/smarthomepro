---
// Αρχείο: src/pages/blog/index.astro
import Layout from '../../layouts/Layout.astro';

// Κάθε νέο άρθρο προστίθεται εδώ ως ένα ακόμα αντικείμενο στη λίστα.
const articles = [
	{
		slug: 'prasino-spiti-knx',
		title: 'Πώς το KNX κάνει το σπίτι σου πιο "πράσινο"',
		description: 'Πώς ο αυτοματισμός KNX μειώνει την ενεργειακή κατανάλωση και πώς ενσωματώνεται με ηλιακά και αντλίες θερμότητας.',
		date: '2026-07-06',
	},
	{
		slug: 'kostos-exypnou-spitiou-knx',
		title: 'Πόσο κοστίζει το έξυπνο σπίτι KNX;',
		description: 'Αναλύουμε τους παράγοντες που καθορίζουν το κόστος μιας εγκατάστασης KNX και δίνουμε ενδεικτικά εύρη τιμών.',
		date: '2026-07-05',
	},
];
---

<Layout
	title="Blog | SmartHomePro - Άρθρα για Έξυπνο Σπίτι KNX"
	description="Χρήσιμα άρθρα και οδηγοί για το έξυπνο σπίτι, την τεχνολογία KNX και τον οικιακό αυτοματισμό στην Αθήνα και την Αττική."
>
	<main class="pt-32 pb-24 bg-white min-h-screen">
		<div class="container mx-auto px-6 max-w-4xl">
			<h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-4">Άρθρα &amp; Οδηγοί</h1>
			<p class="text-lg text-slate-600 mb-16 max-w-2xl">
				Πρακτικές πληροφορίες για το έξυπνο σπίτι KNX — κόστος, τεχνολογία και επιλογές, γραμμένες
				από την ομάδα της SmartHomePro.
			</p>

			<div class="grid gap-8">
				{articles.map((article) => (
					<a
						href={`/blog/${article.slug}/`}
						class="block p-8 border border-slate-100 rounded-xl hover:border-blue-200 hover:shadow-lg transition-all group"
					>
						<h2 class="text-2xl font-bold text-slate-900 mb-2 group-hover:text-blue-600 transition-colors">
							{article.title}
						</h2>
						<p class="text-slate-600">{article.description}</p>
					</a>
				))}
			</div>
		</div>
	</main>
</Layout>
