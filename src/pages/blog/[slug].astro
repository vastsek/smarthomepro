---
// Αρχείο: src/pages/blog/[slug].astro
// Δυναμική σελίδα άρθρου — το περιεχόμενο έρχεται από το collection «blog»
// (src/content/blog/*.mdx). Το url είναι /blog/<όνομα-αρχείου>/.
import { getCollection, render } from 'astro:content';
import { getImage } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, category, publishDate, faqs, cta } = post.data;

const publishDateISO = publishDate.toISOString().slice(0, 10);
const formattedDate = publishDate.toLocaleDateString('el-GR', { year: 'numeric', month: 'long', day: 'numeric' });

// og:image: βελτιστοποιημένη εκδοχή (JPEG, max 1200px) της εικόνας του frontmatter.
const ogImage = post.data.ogImage
	? (await getImage({ src: post.data.ogImage, width: Math.min(1200, post.data.ogImage.width), format: 'jpeg' })).src
	: undefined;

// FAQPage schema — μόνο για άρθρα που ορίζουν faqs στο frontmatter.
const faqSchema = faqs && faqs.length > 0 ? {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faqs.map((f) => ({
		"@type": "Question",
		"name": f.question,
		"acceptedAnswer": { "@type": "Answer", "text": f.answer },
	})),
} : null;
---

<Layout
	title={`${title} | SmartHomePro`}
	description={description}
	publishDate={publishDateISO}
	ogImage={ogImage}
	breadcrumbs={[{ name: 'Αρχική', url: '/' }, { name: 'Blog', url: '/blog/' }, { name: title }]}
>
	{faqSchema && (
		<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	)}

	<main class="pt-40 pb-24">
		<article class="container mx-auto px-6 max-w-3xl">

			<div class="mb-12">
				<a href="/blog/" class="flex w-fit items-center gap-2 text-sm text-slate-500 hover:text-teal-600 transition-colors mb-6">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
						<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
					</svg>
					Πίσω στο Blog
				</a>
				<span class="eyebrow">{category}</span>
				<h1 class="text-3xl md:text-5xl font-bold text-slate-900 mt-2 mb-4 leading-tight">
					{title}
				</h1>
				<time datetime={publishDateISO} class="text-slate-400 text-sm">{formattedDate}</time>
			</div>

			<div class="space-y-10 text-slate-700 text-lg leading-relaxed">
				<Content />
			</div>

			<div class="mt-16 p-8 bg-dark-glow rounded-xl text-center">
				<h3 class:list={["text-2xl font-bold text-white", cta.text ? 'mb-3' : 'mb-4']}>{cta.heading}</h3>
				{cta.text && <p class="text-slate-300 mb-6">{cta.text}</p>}
				<a href="/#contact" class="inline-block px-8 py-4 bg-teal-600 text-white text-base font-medium rounded hover:bg-teal-500 transition-colors shadow-lg">
					{cta.button}
				</a>
			</div>

		</article>
	</main>
</Layout>
